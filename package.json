{
  "name": "shoofly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "node --no-warnings ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint",
    "db:check": "node scripts/check-env.mjs && prisma validate && prisma migrate status",
    "db:migrate": "node scripts/check-env.mjs && prisma migrate deploy",
    "db:seed": "node scripts/check-env.mjs && prisma db seed",
    "db:reset": "node scripts/check-env.mjs && prisma migrate reset --force",
    "setup:db": "npm run db:check && npm run db:migrate && npm run db:seed",
    "seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "test:full-flow": "tsx --tsconfig tsconfig.test.json tests/full-flow-test.ts",
    "test:feedback": "tsx --tsconfig tsconfig.test.json tests/feedback-test.ts",
    "test:category": "tsx --tsconfig tsconfig.test.json tests/category-enforcement-test.ts",
    "test": "npm run test:roles && npm run test:client && npm run test:vendor && npm run test:delivery && npm run test:admin && npm run test:category && npm run test:feedback && npm run test:full-flow",
    "test:roles": "tsx --tsconfig tsconfig.test.json tests/all-roles-test.ts",
    "test:client": "tsx --tsconfig tsconfig.test.json tests/client-logic-test.ts",
    "test:vendor": "tsx --tsconfig tsconfig.test.json tests/vendor-logic-test.ts",
    "test:delivery": "tsx --tsconfig tsconfig.test.json tests/delivery-logic-test.ts",
    "test:admin": "tsx --tsconfig tsconfig.test.json tests/admin-logic-test.ts",
    "test:transactions": "tsx --tsconfig tsconfig.test.json tests/transactions-scenarios-test.ts",
    "test:ui": "python scripts/with_server.py --server \"npm run dev\" --port 5000 -- python -u tests/ui_verification.py",
    "analyze": "cross-env ANALYZE=true next build",
    "perf:check": "npx tsx --tsconfig tsconfig.test.json tests/performance-test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-google-maps/api": "^2.20.8",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next": "^16.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
