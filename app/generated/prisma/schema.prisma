generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       Int                 @id @default(autoincrement())
  fullName                 String
  email                    String              @unique
  password                 String
  phone                    String?
  phoneVerified            Boolean             @default(false)
  phoneVerifiedAt          DateTime?
  role                     UserRole
  isActive                 Boolean             @default(true)
  isVerified               Boolean             @default(false)
  verificationStatus       VerificationStatus  @default(NOT_SUBMITTED)
  isBlocked                Boolean             @default(false)
  trustScore               Int                 @default(100)
  suspendedUntil           DateTime?
  suspensionReason         String?
  walletBalance            Decimal             @default(0) @db.Decimal(12, 2)
  fcmToken                 String?
  cityId                   Int?
  governorateId            Int?
  nationalId               String?             @unique
  vehicleType              String?
  licensePlate             String?
  latitude                 Float?
  longitude                Float?
  vendorAddress            String?
  idCardFrontUrl           String?
  idCardBackUrl            String?
  kycSubmissionDate        DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  adminAuditLogs           AdminAuditLog[]     @relation("AdminAuditLogs")
  vendorBids               Bid[]
  receivedMessages         ChatMessage[]       @relation("ReceivedMessages")
  sentMessages             ChatMessage[]       @relation("SentMessages")
  complaintsReceived       Complaint[]         @relation("ReportedUserComplaints")
  resolvedComplaints       Complaint[]         @relation("AdminResolvedComplaints")
  complaints               Complaint[]         @relation("UserComplaints")
  notifications            Notification[]
  paymentAttempts          PaymentAttempt[]
  assignedDeliveries       Request[]           @relation("DeliveryAgent")
  clientRequests           Request[]           @relation("ClientRequests")
  reviewsReceived          Review[]            @relation("ReviewsReceived")
  reviewsGiven             Review[]            @relation("ReviewsGiven")
  transactions             Transaction[]
  trustEvents              TrustEvent[]
  requestReportsFiled      RequestReport[]     @relation("ReportFiler")
  phoneOtps                PhoneOtp[]
  city                     City?               @relation(fields: [cityId], references: [id])
  governorate              Governorate?        @relation(fields: [governorateId], references: [id])
  vendorBrands             VendorBrand[]
  vendorCategories         VendorCategory[]
  adminReviewedWithdrawals WithdrawalRequest[] @relation("AdminWithdrawalReviews")
  vendorWithdrawals        WithdrawalRequest[] @relation("VendorWithdrawals")

  @@index([email])
  @@index([role])
  @@index([phone])
  @@index([isActive, isVerified])
  @@index([verificationStatus])
  @@index([trustScore])
  @@index([suspendedUntil])
}

model Category {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  slug          String           @unique
  parentId      Int?
  requiresBrand Boolean          @default(false)
  brandType     String?
  type          CategoryType     @default(SERVICE)
  nameAr        String?
  createdAt     DateTime         @default(now())
  parent        Category?        @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  subcategories Category[]       @relation("CategoryToSubcategory")
  requests      Request[]
  vendors       VendorCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([brandType])
  @@index([type])
}

model Brand {
  id        Int           @id @default(autoincrement())
  name      String
  slug      String        @unique
  type      String
  logo      String?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  requests  Request[]
  vendors   VendorBrand[]

  @@index([type])
  @@index([slug])
}

model VendorBrand {
  id       Int   @id @default(autoincrement())
  vendorId Int
  brandId  Int
  brand    Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  vendor   User  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, brandId])
  @@index([vendorId])
  @@index([brandId])
}

model VendorCategory {
  id         Int      @id @default(autoincrement())
  vendorId   Int
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vendor     User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId])
  @@index([vendorId])
  @@index([categoryId])
}

model Request {
  id                      Int                @id @default(autoincrement())
  clientId                Int
  title                   String
  description             String
  categoryId              Int
  brandId                 Int?
  address                 String
  latitude                Decimal            @db.Decimal(10, 7)
  longitude               Decimal            @db.Decimal(10, 7)
  deliveryPhone           String
  budget                  Decimal?           @db.Decimal(12, 2)
  notes                   String?
  status                  RequestStatus      @default(PENDING_ADMIN_REVISION)
  selectedBidId           Int?               @unique
  qrCode                  String?
  assignedDeliveryAgentId Int?
  cityId                  Int?
  governorateId           Int?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  bids                    Bid[]
  complaints              Complaint[]
  reports                 RequestReport[]
  deliveryTracking        DeliveryTracking[]
  notifications           Notification[]
  deliveryAgent           User?              @relation("DeliveryAgent", fields: [assignedDeliveryAgentId], references: [id])
  brand                   Brand?             @relation(fields: [brandId], references: [id])
  category                Category           @relation(fields: [categoryId], references: [id])
  city                    City?              @relation(fields: [cityId], references: [id])
  client                  User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  governorate             Governorate?       @relation(fields: [governorateId], references: [id])
  images                  RequestImage[]
  review                  Review?
  transactions            Transaction[]
  chatMessages            ChatMessage[]

  @@index([clientId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status, categoryId])
  @@index([latitude, longitude])
  @@index([assignedDeliveryAgentId])
  @@index([createdAt])
  @@index([status])
}

model RequestImage {
  id        Int      @id @default(autoincrement())
  requestId Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Bid {
  id          Int        @id @default(autoincrement())
  requestId   Int
  vendorId    Int
  description String
  netPrice    Decimal    @db.Decimal(12, 2)
  clientPrice Decimal    @db.Decimal(12, 2)
  duration    String?
  status      BidStatus  @default(PENDING)
  adminNote   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  request     Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendor      User       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  images      BidImage[]

  @@unique([requestId, vendorId])
  @@index([requestId])
  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model BidImage {
  id        Int      @id @default(autoincrement())
  bidId     Int
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  createdAt DateTime @default(now())
  bid       Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
}

model DeliveryTracking {
  id           Int            @id @default(autoincrement())
  requestId    Int
  status       DeliveryStatus
  latitude     Decimal?       @db.Decimal(10, 7)
  longitude    Decimal?       @db.Decimal(10, 7)
  speed        Decimal?       @db.Decimal(5, 2)
  note         String?
  locationText String?
  createdAt    DateTime       @default(now())
  request      Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status])
}

/// Vendor reports on a request (fake/spam/duplicate/...).
model RequestReport {
  id           Int      @id @default(autoincrement())
  requestId    Int
  reportedById Int
  reason       String
  details      String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reportedBy   User     @relation("ReportFiler", fields: [reportedById], references: [id], onDelete: Cascade)

  @@unique([requestId, reportedById])
  @@index([requestId])
  @@index([reportedById])
  @@index([resolved])
}

/// Append-only trust score audit log for a user.
model TrustEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  delta     Int
  reason    String
  actorId   Int?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// One-time-password codes sent to a user's phone for verification.
model PhoneOtp {
  id        Int        @id @default(autoincrement())
  userId    Int
  phone     String
  codeHash  String
  purpose   OtpPurpose @default(PHONE_VERIFY)
  attempts  Int        @default(0)
  consumed  Boolean    @default(false)
  expiresAt DateTime
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumed, expiresAt])
  @@index([phone, purpose])
}

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int
  requestId   Int?
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  request     Request?        @relation(fields: [requestId], references: [id])
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([requestId])
  @@index([type])
  @@index([createdAt])
}

model PaymentAttempt {
  id         Int      @id @default(autoincrement())
  userId     Int
  amount     Decimal  @db.Decimal(12, 2)
  provider   String
  externalId String?  @unique
  status     String   @default("PENDING")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([externalId])
  @@index([status])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  requestId Int?
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  request   Request?         @relation(fields: [requestId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  requestId  Int
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id           Int              @id @default(autoincrement())
  vendorId     Int
  amount       Decimal          @db.Decimal(12, 2)
  status       WithdrawalStatus @default(PENDING)
  reviewNote   String?
  reviewedById Int?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  reviewedBy   User?            @relation("AdminWithdrawalReviews", fields: [reviewedById], references: [id])
  vendor       User             @relation("VendorWithdrawals", fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@index([reviewedById])
  @@index([createdAt])
}

model PlatformSetting {
  id                    Int      @id @default(autoincrement())
  commissionPercent     Decimal  @default(15) @db.Decimal(5, 2)
  vatPercent            Decimal  @default(14) @db.Decimal(5, 2)
  minOrderAmount        Decimal  @default(100) @db.Decimal(12, 2)
  minVendorMatchCount   Int      @default(3)
  initialRadiusKm       Int      @default(5)
  maxRadiusKm           Int      @default(50)
  radiusExpansionStepKm Int      @default(5)
  autoPayoutEnabled     Boolean  @default(true)
  verifyRequired        Boolean  @default(true)
  otpDeliveryEnabled    Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  requestId  Int      @unique
  reviewerId Int
  reviewedId Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewed   User     @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([requestId, reviewerId])
  @@index([reviewedId])
}

model Complaint {
  id             Int             @id @default(autoincrement())
  requestId      Int
  userId         Int
  subject        String
  description    String
  status         ComplaintStatus @default(OPEN)
  resolution     String?
  resolvedById   Int?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reportedUserId Int?
  reportedUser   User?           @relation("ReportedUserComplaints", fields: [reportedUserId], references: [id])
  request        Request         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  resolvedBy     User?           @relation("AdminResolvedComplaints", fields: [resolvedById], references: [id])
  user           User            @relation("UserComplaints", fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([userId])
  @@index([reportedUserId])
  @@index([status])
}

model Governorate {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  nameAr   String?   @unique
  cities   City[]
  requests Request[]
  users    User[]
}

model City {
  id            Int         @id @default(autoincrement())
  name          String
  nameAr        String?
  governorateId Int
  governorate   Governorate @relation(fields: [governorateId], references: [id])
  requests      Request[]
  users         User[]

  @@index([governorateId])
}

model AdminAuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String
  targetType String
  targetId   Int?
  oldValue   String?
  newValue   String?
  metadata   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
  DELIVERY
}

enum RequestStatus {
  PENDING_ADMIN_REVISION
  OPEN_FOR_BIDDING
  BIDS_RECEIVED
  OFFERS_FORWARDED
  ORDER_PAID_PENDING_DELIVERY
  CLOSED_SUCCESS
  CLOSED_CANCELLED
  REJECTED
}

enum BidStatus {
  PENDING
  SELECTED
  ACCEPTED_BY_CLIENT
  REJECTED
  WITHDRAWN
}

enum DeliveryStatus {
  ORDER_PLACED
  VENDOR_PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  IN_TRANSIT
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  ESCROW_DEPOSIT
  VENDOR_PAYOUT
  DELIVERY_PAYOUT
  ADMIN_COMMISSION
  REFUND
  WITHDRAWAL
  WALLET_TOPUP
}

enum NotificationType {
  NEW_REQUEST
  NEW_BID
  OFFER_RECEIVED
  BID_ACCEPTED
  DELIVERY_UPDATE
  DELIVERY_FAILED
  PAYMENT_RECEIVED
  REFUND_ISSUED
  REQUEST_DISPATCHED
  WALLET_TOPUP
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_REQUESTED
  REQUEST_CANCELLED
  REQUEST_REJECTED
  REQUEST_NEEDS_REVISION
  DISPUTE_RAISED
  DISPUTE_RESOLVED
  KYC_APPROVED
  KYC_REJECTED
  PHONE_OTP
  REQUEST_REPORTED
  REQUEST_AUTO_CLOSED
  USER_SUSPENDED
  USER_REINSTATED
  AI_FLAGGED_REQUEST
}

enum OtpPurpose {
  PHONE_VERIFY
  LOGIN
}

enum CategoryType {
  SERVICE
  PRODUCT
  DIGITAL
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}
